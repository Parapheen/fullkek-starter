{{- $lb := "{{" -}}
{{- $rb := "}}" -}}
{{ printf "%s define \"title\" %s%s · Launch faster%s end %s\n" $lb $rb .AppName $lb $rb }}
{{ printf "%s define \"body_class\" %smin-h-screen bg-base-100 text-base-content%s end %s\n" $lb $rb $lb $rb }}
{{ printf "%s define \"head\" %s\n" $lb $rb }}
    <link rel="stylesheet" href="/assets/styles/custom.css" />
{{ printf "%s end %s\n" $lb $rb }}
{{ printf "%s define \"content\" %s\n" $lb $rb }}
  <section id="hero" class="bg-base-100 py-24">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1 class="text-5xl font-semibold leading-tight text-base-content sm:text-6xl">
        {{ .AppName }} just works.
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg opacity-80">
        Assemble authentication, data, and UI foundations without wrestling config. Customize later—begin shipping today with the essentials in place.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a class="btn btn-primary btn-lg" href="#get-started">Get started</a>
        <a class="btn btn-ghost btn-lg" href="#features">Explore features</a>
      </div>
    </div>
  </section>
  <section class="bg-base-200 py-6">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-4 px-6 text-xs font-semibold uppercase tracking-[0.3em] text-base-content/70">
      <span>Fast to start</span>
      <span>Batteries included</span>
      <span>Modern UX</span>
      <span>Production ready</span>
    </div>
  </section>
  <section id="features" class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-10 text-center">
        <h2 class="mt-3 text-3xl font-semibold text-base-content">Everything you need to launch and grow</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="card border border-base-200 bg-base-100/70 shadow-sm backdrop-blur">
          <div class="card-body">
            <div class="badge badge-primary badge-outline w-fit">Auth</div>
            <h3 class="card-title mt-3">Secure sign-in flows</h3>
            <p class="opacity-80">Ready-to-wire authentication with opinionated defaults and easy provider swaps.</p>
          </div>
        </div>
        <div class="card border border-base-200 bg-base-100/70 shadow-sm backdrop-blur">
          <div class="card-body">
            <div class="badge badge-secondary badge-outline w-fit">Data</div>
            <h3 class="card-title mt-3">Persistent storage</h3>
            <p class="opacity-80">Start with embedded storage, then switch to your preferred database without rewrites.</p>
          </div>
        </div>
        <div class="card border border-base-200 bg-base-100/70 shadow-sm backdrop-blur">
          <div class="card-body">
            <div class="badge badge-accent badge-outline w-fit">Frontend</div>
            <h3 class="card-title mt-3">Interactive UI</h3>
            <p class="opacity-80">Server-driven components pair with progressive enhancement for fast perceived speed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="py-16">
    <div class="mx-auto max-w-5xl rounded-3xl border border-base-200 bg-base-100 px-8 py-12 text-center shadow-lg">
      <p class="text-lg italic text-base-content/80">
        “{{ .AppName }} gave us a credible MVP in a weekend. DaisyUI kept the look polished while Go handled the scale.”
      </p>
      <div class="mt-6 text-sm font-semibold uppercase tracking-[0.3em] text-base-content/60">Product Teams Everywhere</div>
    </div>
  </section>
{{ printf "%s end %s\n" $lb $rb }}
{{ printf "%s template \"base\" . %s\n" $lb $rb }}
