---
- name: Deploy {{ .AppName }}
  hosts: webservers
  become: true
  vars_files:
    - group_vars/all.yml

  tasks:
    - name: Install system dependencies
      apt:
        name:
          - git
          - curl
          - debian-keyring
          - debian-archive-keyring
          - apt-transport-https
        state: present
        update_cache: true

    - name: Install Go {{ "{{ go_version }}" }}
      shell: |
        if ! command -v go &> /dev/null || ! go version | grep -q "go{{ "{{ go_version }}" }}"; then
          curl -sL "https://go.dev/dl/go{{ "{{ go_version }}" }}.linux-amd64.tar.gz" | tar -C /usr/local -xzf -
        fi
      args:
        creates: /usr/local/go/bin/go

    - name: Add Go to PATH
      lineinfile:
        path: /etc/profile.d/go.sh
        line: 'export PATH=$PATH:/usr/local/go/bin'
        create: true
        mode: '0644'

    - name: Install Caddy
      shell: |
        curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg
        curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | tee /etc/apt/sources.list.d/caddy-stable.list
        apt-get update
        apt-get install -y caddy
      args:
        creates: /usr/bin/caddy

    - name: Create app user
      user:
        name: "{{ "{{ app_user }}" }}"
        system: true
        shell: /usr/sbin/nologin
        home: "/opt/{{ "{{ app_name }}" }}"
        create_home: true

    - name: Create app directory
      file:
        path: "/opt/{{ "{{ app_name }}" }}"
        state: directory
        owner: "{{ "{{ app_user }}" }}"
        group: "{{ "{{ app_user }}" }}"
        mode: '0755'

    - name: Copy source to server
      synchronize:
        src: "{{ "{{ playbook_dir }}" }}/../"
        dest: "/opt/{{ "{{ app_name }}" }}/"
        rsync_opts:
          - "--exclude=.git"
          - "--exclude=bin/"
          - "--exclude=data/"

    - name: Build application
      shell: |
        export PATH=$PATH:/usr/local/go/bin
        cd /opt/{{ "{{ app_name }}" }}
        go build -o bin/{{ "{{ app_name }}" }} ./cmd/server
      become_user: "{{ "{{ app_user }}" }}"

{{- if .Stack.HasFeature "database-sqlite" }}

    - name: Create data directory
      file:
        path: "/opt/{{ "{{ app_name }}" }}/data"
        state: directory
        owner: "{{ "{{ app_user }}" }}"
        group: "{{ "{{ app_user }}" }}"
        mode: '0755'

    - name: Install goose and run migrations
      shell: |
        export PATH=$PATH:/usr/local/go/bin
        cd /opt/{{ "{{ app_name }}" }}
        GOBIN=$(pwd)/bin go install github.com/pressly/goose/v3/cmd/goose@latest
        if [ -d db/migrations ]; then
          ./bin/goose -dir db/migrations sqlite3 data/app.db up
        fi
      become_user: "{{ "{{ app_user }}" }}"
{{- end }}

    - name: Deploy systemd service
      template:
        src: templates/app.service.j2
        dest: "/etc/systemd/system/{{ "{{ app_name }}" }}.service"
        mode: '0644'
      notify: restart app

    - name: Deploy Caddyfile
      template:
        src: templates/Caddyfile.j2
        dest: /etc/caddy/Caddyfile
        mode: '0644'
      notify: restart caddy

    - name: Enable and start app service
      systemd:
        name: "{{ "{{ app_name }}" }}"
        enabled: true
        state: started
        daemon_reload: true

    - name: Enable and start Caddy
      systemd:
        name: caddy
        enabled: true
        state: started

  handlers:
    - name: restart app
      systemd:
        name: "{{ "{{ app_name }}" }}"
        state: restarted
        daemon_reload: true

    - name: restart caddy
      systemd:
        name: caddy
        state: reloaded
