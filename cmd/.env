# Example environment configuration for fullkek

# Server
# Address for the HTTP server to listen on
SERVER_ADDR=:3333
# SQLite
# Optional DSN; leave empty to use the scaffold's built-in default
# Example: file:data/app.db?cache=shared&_pragma=busy_timeout(5000)&_pragma=foreign_keys(ON)&_pragma=journal_mode(WAL)
SQLITE_DSN=file:data/app.db?cache=shared&_pragma=busy_timeout(5000)&_pragma=foreign_keys(ON)&_pragma=journal_mode(WAL)

# GitHub OAuth
GITHUB_CLIENT_ID=Iv1.07867ac0ed9df4f4
GITHUB_CLIENT_SECRET=0ec17504ad9dd349630a0e8835f0a53687f2235c
# Callback URL must match your GitHub OAuth app settings
OAUTH_CALLBACK_URL=http://localhost:3333/auth/github/callback

SESSION_COOKIE_NAME=sid
SESSION_TTL_DAYS=30


